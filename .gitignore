# ML / Model weights — inference weights are tracked via Git LFS (.gitattributes).
# Keep training-only artifacts out of the repo:
models/weights/
models/checkpoints/
models/deberta/final/      # redundant training checkpoint (best/ is used at runtime)
*.log

# Data (raw/large datasets - keep structure, ignore content)
data/raw/
data/processed/sessions/
data/processed/*.npy
data/processed/*.npz
data/embeddings/sessions/
data/embeddings/*.npy
data/embeddings/*.pkl
data/labeled/sessions/
data/exports/deberta/
data/exports/sklearn/
data/exports/fusion/
data/.validation_cache.json

# Audio/Video uploads (runtime artifacts)
uploads/
*.wav
*.mp3
*.mp4
*.webm
*.avi

# Logs
*.log
logs/

# Database
*.db
*.sqlite3

# Archives
archive/

# Tool internals
.claude/

# Temp files
requirements_temp.txt

# Test cache
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
*.spec

# OS
desktop.ini

# Node / Next.js (frontend)
node_modules/
.next/
out/
npm-debug.log*

# Data-pipeline pickles stay out of git (model .pkl weights are LFS-tracked).
data/**/*.pkl

# Build / runtime artifacts
*.tsbuildinfo
data/*.db
data/*.db-wal
data/*.db-shm
data/uploads/
